{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out/webview",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "rootDir": "src/webview",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "jsx": "react"
  },
  "include": ["src/webview/**/*"],
  "exclude": ["node_modules", "out"]
}
